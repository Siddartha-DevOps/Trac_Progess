# ==============================================================================
# Enterprise Computer Vision Platform - Environment Configuration Example
# ==============================================================================

# Core Application Settings
APP_NAME="BuildTrace CV Inference Platform"
APP_ENV="production"  # development, staging, production
DEBUG=false
API_V1_STR="/api/v1"
SECRET_KEY="replace-this-with-a-secure-random-32-character-hex-string"

# Server Host & Ports
HOST="0.0.0.0"
PORT=3000

# PostgreSQL Database Configuration (Async Engine)
POSTGRES_SERVER="localhost"
POSTGRES_USER="buildtrace_admin"
POSTGRES_PASSWORD="secure_db_password_98231"
POSTGRES_DB="buildtrace_cv_prod"
POSTGRES_PORT=5432
DATABASE_URL="postgresql+asyncpg://buildtrace_admin:secure_db_password_98231@localhost:5432/buildtrace_cv_prod"

# Redis Broker Configuration (Celery / BullMQ / Job Cache)
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""
REDIS_DB=0
REDIS_URL="redis://localhost:6379/0"

# AWS S3 Storage Config (Object Walkthrough Ingestion)
AWS_ACCESS_KEY_ID="AKIA_REPLACE_WITH_REAL_ACCESS_KEY_ID"
AWS_SECRET_ACCESS_KEY="REPLACE_WITH_REAL_SECRET_ACCESS_KEY"
AWS_REGION="ap-south-1"  # Mumbai Region
S3_BUCKET_RAW_VIDEOS="buildtrace-mumbai-raw-walkthroughs"
S3_BUCKET_EXTRACTED_FRAMES="buildtrace-mumbai-processed-frames"

# Computer Vision & Inference Parameters
CUDA_VISIBLE_DEVICES="0"            # Use "0,1" for multi-GPU setups
YOLO_WEIGHTS_PATH="/app/weights/yolov11x-seg.pt"
SAM_WEIGHTS_PATH="/app/weights/sam2_hiera_large.pt"
INFERENCE_CONFIDENCE_THRESHOLD=0.35
MAX_BATCH_SIZE=8                    # Image batching for GPU throughput
TARGET_DEWARP_FPS=1.5               # Frame extraction rate from raw videos

# Spatial Point Cloud & Registration Parameters
ICP_MAX_CORRESPONDENCE_DISTANCE=0.05 # 5cm threshold for Iterative Closest Point matching
ICP_VOXEL_SIZE=0.02                  # 2cm downsampling voxel grid size
MAX_ALIGNMENT_RETRY_ATTEMPTS=3

# Logging & Telemetry
LOG_LEVEL="INFO"                    # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT="json"                   # "json" for CloudWatch/Grafana, "console" for dev
ENABLE_PROMETHEUS_METRICS=true
